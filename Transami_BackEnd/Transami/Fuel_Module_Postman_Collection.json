{
  "info": {
    "name": "Transami - Module Carburant",
    "description": "Collection complète pour tester le module de gestion du carburant",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_JWT_TOKEN_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Prix Carburant",
      "item": [
        {
          "name": "Créer/Mettre à jour les prix",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prixEssence\": 2.150,\n  \"prixDiesel\": 1.950,\n  \"prixDiesel50\": 2.050\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/prix-carburant",
              "host": ["{{baseUrl}}"],
              "path": ["prix-carburant"]
            }
          }
        },
        {
          "name": "Obtenir les prix configurés",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/prix-carburant",
              "host": ["{{baseUrl}}"],
              "path": ["prix-carburant"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Stations",
      "item": [
        {
          "name": "Créer une station",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Station Total Tunis Centre\",\n  \"localisation\": \"Avenue Habib Bourguiba, Tunis\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/stations",
              "host": ["{{baseUrl}}"],
              "path": ["stations"]
            }
          }
        },
        {
          "name": "Obtenir toutes les stations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
