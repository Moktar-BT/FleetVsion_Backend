            "url": {
              "raw": "{{baseUrl}}/stations",
              "host": ["{{baseUrl}}"],
              "path": ["stations"]
            }
          }
        },
        {
          "name": "Obtenir une station par ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/stations/1",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "1"]
            }
          }
        },
        {
          "name": "Modifier une station",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Station Total Tunis Centre Ville\",\n  \"localisation\": \"Avenue Habib Bourguiba, Tunis 1000\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/stations/1",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "1"]
            }
          }
        },
        {
          "name": "Supprimer une station",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/stations/1",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "1"]
            }
          }
        }
      ]
    },
